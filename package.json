{
  "name": "hitstop",
  "version": "0.1.2",
  "description": "A 2D action game engine where game feel is a first-class primitive.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "build:single": "tsc --noEmit && vite build -c vite.config.single.ts && node -e \"require('fs').copyFileSync('dist-single/index.html', 'hitstop.html')\"",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "replay": "node tools/agent-play/replay.mjs",
    "agent-play": "node tools/agent-play/server.mjs"
  },
  "devDependencies": {
    "playwright": "^1.61.1",
    "typescript": "^5.5.0",
    "vite": "^5.4.0",
    "vite-plugin-singlefile": "^2.3.3"
  }
}
